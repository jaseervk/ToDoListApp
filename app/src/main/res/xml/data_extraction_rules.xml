<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    Excludes the Room database from cloud backup to prevent
    restore crashes when the DB schema changes between versions.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="todo_database" />
        <exclude domain="database" path="todo_database-shm" />
        <exclude domain="database" path="todo_database-wal" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="todo_database" />
        <include domain="database" path="todo_database-shm" />
        <include domain="database" path="todo_database-wal" />
    </device-transfer>
</data-extraction-rules>
